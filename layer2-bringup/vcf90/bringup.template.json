{
  "_comment": "VCF 9.0 Management Domain Bring-up Spec. 結構對齊 William Lam autodeployvcf9m01.ps1 / VCF Installer 9.0 OpenAPI. 由 Generate-BringupSpec.ps1 -Version 9.0 從 inventory/lab.yaml 渲染.",

  "sddcId":              "{{ vcf.management_domain.name }}",
  "workflowType":        "VCF",
  "vcfInstanceName":     "{{ vcf.management_domain.name }}",
  "managementPoolName":  "{{ vcf.management_domain.name }}-np01",
  "ceipEnabled":         false,
  "fipsEnabled":         false,
  "version":             "9.0.2.0",

  "skipEsxThumbprintValidation": true,
  "skipGatewayPingValidation":   true,
  "_lab_note_skip": "上兩個 skip 為 lab workaround; 正式環境設 false 並提供真實 thumbprint",

  "dnsSpec": {
    "subdomain":   "{{ lab.domain }}",
    "domain":      "{{ lab.domain }}",
    "nameservers": [ "{{ infra.ad_dns.ip }}" ]
  },

  "ntpServers": [ "{{ infra.ad_dns.ip }}" ],

  "rootUserCredentials": {
    "username": "root",
    "password": "{{ secrets.deploy_defaults.vm_root_pw }}"
  },

  "sddcManagerSpec": {
    "hostname":          "{{ vcf.management_domain.sddc_manager.fqdn }}",
    "ipAddress":         "{{ vcf.management_domain.sddc_manager.ip | default '192.168.114.10' }}",
    "rootPassword":      "{{ secrets.sddc_manager.root_pw }}",
    "sshPassword":       "{{ secrets.sddc_manager.root_pw }}",
    "localUserPassword": "{{ secrets.sddc_manager.admin_pw }}",
    "useExistingDeployment": false
  },

  "vcenterSpec": {
    "vcenterHostname":       "{{ vcf.management_domain.inner_vcenter.fqdn }}",
    "vcenterIp":             "{{ vcf.management_domain.inner_vcenter.ip | default '192.168.114.11' }}",
    "rootVcenterPassword":   "{{ secrets.inner_vcenter.sso_admin_pw }}",
    "vmSize":                "small",
    "storageSize":           "lstorage",
    "ssoDomain":             "vsphere.local",
    "adminUserSsoPassword":  "{{ secrets.inner_vcenter.sso_admin_pw }}",
    "useExistingDeployment": false,
    "datacenterName":        "{{ vcf.management_domain.name }}-dc01",
    "clusterName":           "{{ vcf.management_domain.name }}-cl01"
  },

  "clusterSpec": {
    "datacenterName": "{{ vcf.management_domain.name }}-dc01",
    "clusterName":    "{{ vcf.management_domain.name }}-cl01",
    "clusterEvcMode": ""
  },

  "dvsSpecs": [
    {
      "dvsName":  "{{ vcf.management_domain.name }}-vds01",
      "networks": [ "MANAGEMENT", "VM_MANAGEMENT", "VMOTION", "VSAN" ],
      "mtu":      9000,
      "nsxtSwitchConfig": {
        "transportZones": [
          { "name": "VCF-Created-Overlay-Zone", "transportType": "OVERLAY" }
        ]
      },
      "vmnicsToUplinks": [
        { "id": "vmnic0", "uplink": "uplink1" },
        { "id": "vmnic1", "uplink": "uplink2" }
      ],
      "nsxTeamings": [
        { "policy": "LOADBALANCE_SRCID", "activeUplinks": [ "uplink1", "uplink2" ] }
      ]
    }
  ],

  "networkSpecs": [
    {
      "networkType":   "MANAGEMENT",
      "subnet":        "{{ network.mgmt.cidr }}",
      "gateway":       "{{ network.mgmt.gateway }}",
      "vlanId":        {{ network.mgmt.vlan }},
      "mtu":           1500,
      "teamingPolicy": "loadbalance_loadbased",
      "activeUplinks": [ "uplink1", "uplink2" ],
      "portGroupKey":  "{{ vcf.management_domain.name }}-vds01-pg-esx-mgmt"
    },
    {
      "networkType":   "VM_MANAGEMENT",
      "subnet":        "{{ network.mgmt.cidr }}",
      "gateway":       "{{ network.mgmt.gateway }}",
      "vlanId":        {{ network.mgmt.vlan }},
      "mtu":           1500,
      "teamingPolicy": "loadbalance_loadbased",
      "activeUplinks": [ "uplink1", "uplink2" ],
      "portGroupKey":  "{{ vcf.management_domain.name }}-vds01-pg-vm-mgmt"
    },
    {
      "networkType":   "VMOTION",
      "subnet":        "{{ network.vmotion.cidr }}",
      "gateway":       "{{ network.vmotion.gateway }}",
      "vlanId":        {{ network.vmotion.vlan }},
      "mtu":           9000,
      "teamingPolicy": "loadbalance_loadbased",
      "activeUplinks": [ "uplink1", "uplink2" ],
      "includeIpAddressRanges": [
        { "startIpAddress": "{{ network.vmotion.range_start }}", "endIpAddress": "{{ network.vmotion.range_end }}" }
      ],
      "portGroupKey":  "{{ vcf.management_domain.name }}-vds01-pg-vmotion"
    },
    {
      "networkType":   "VSAN",
      "subnet":        "{{ network.vsan.cidr }}",
      "gateway":       "{{ network.vsan.gateway }}",
      "vlanId":        {{ network.vsan.vlan }},
      "mtu":           9000,
      "teamingPolicy": "loadbalance_loadbased",
      "activeUplinks": [ "uplink1", "uplink2" ],
      "includeIpAddressRanges": [
        { "startIpAddress": "{{ network.vsan.range_start }}", "endIpAddress": "{{ network.vsan.range_end }}" }
      ],
      "portGroupKey":  "{{ vcf.management_domain.name }}-vds01-pg-vsan"
    }
  ],

  "nsxtSpec": {
    "nsxtManagerSize": "medium",
    "nsxtManagers": [
      {
        "hostname": "{{ vcf.management_domain.nsx_manager.node_fqdn }}",
        "ip":       "{{ vcf.management_domain.nsx_manager.node_ip }}"
      }
    ],
    "vip":                       "{{ vcf.management_domain.nsx_manager.vip }}",
    "vipFqdn":                   "{{ vcf.management_domain.nsx_manager.fqdn }}",
    "rootNsxtManagerPassword":   "{{ secrets.nsx.admin_pw }}",
    "nsxtAdminPassword":         "{{ secrets.nsx.admin_pw }}",
    "nsxtAuditPassword":         "{{ secrets.nsx.admin_pw }}",
    "transportVlanId":           {{ network.overlay.vlan }},
    "ipAddressPoolSpec": {
      "name":        "nsx-tep-{{ vcf.management_domain.name }}",
      "description": "NSX TEP Pool for {{ vcf.management_domain.name }}",
      "subnets": [
        {
          "ipAddressPoolRanges": [
            { "start": "{{ vcf.management_domain.tep_pool.range_start }}", "end": "{{ vcf.management_domain.tep_pool.range_end }}" }
          ],
          "cidr":    "{{ vcf.management_domain.tep_pool.cidr }}",
          "gateway": "{{ vcf.management_domain.tep_pool.gateway }}"
        }
      ]
    },
    "skipNsxOverlayOverManagementNetwork": true,
    "useExistingDeployment":               false
  },

  "datastoreSpec": {
    "vsanSpec": {
      "datastoreName":      "{{ vcf.management_domain.name }}-vsan01",
      "failuresToTolerate": 0,
      "esaConfig": { "enabled": false },
      "_lab_note_vsan": "VCF 9.0 nested 預設關 ESA (OSA 更穩). 想開 ESA 改 enabled=true 並用 -LabMode 注入 skip HCL"
    }
  },

  "hostSpecs": [
    {
      "association": "{{ vcf.management_domain.name }}-dc01",
      "hostname":    "{{ hosts[0].fqdn }}",
      "ipAddressPrivate": { "ipAddress": "{{ hosts[0].mgmt_ip }}", "cidr": "{{ network.mgmt.cidr }}", "gateway": "{{ network.mgmt.gateway }}" },
      "credentials": { "username": "root", "password": "{{ secrets.esxi.root_pw }}" },
      "sslThumbprint": "REPLACE_OR_SKIP"
    },
    {
      "association": "{{ vcf.management_domain.name }}-dc01",
      "hostname":    "{{ hosts[1].fqdn }}",
      "ipAddressPrivate": { "ipAddress": "{{ hosts[1].mgmt_ip }}", "cidr": "{{ network.mgmt.cidr }}", "gateway": "{{ network.mgmt.gateway }}" },
      "credentials": { "username": "root", "password": "{{ secrets.esxi.root_pw }}" },
      "sslThumbprint": "REPLACE_OR_SKIP"
    },
    {
      "association": "{{ vcf.management_domain.name }}-dc01",
      "hostname":    "{{ hosts[2].fqdn }}",
      "ipAddressPrivate": { "ipAddress": "{{ hosts[2].mgmt_ip }}", "cidr": "{{ network.mgmt.cidr }}", "gateway": "{{ network.mgmt.gateway }}" },
      "credentials": { "username": "root", "password": "{{ secrets.esxi.root_pw }}" },
      "sslThumbprint": "REPLACE_OR_SKIP"
    },
    {
      "association": "{{ vcf.management_domain.name }}-dc01",
      "hostname":    "{{ hosts[3].fqdn }}",
      "ipAddressPrivate": { "ipAddress": "{{ hosts[3].mgmt_ip }}", "cidr": "{{ network.mgmt.cidr }}", "gateway": "{{ network.mgmt.gateway }}" },
      "credentials": { "username": "root", "password": "{{ secrets.esxi.root_pw }}" },
      "sslThumbprint": "REPLACE_OR_SKIP"
    }
  ],

  "vcfOperationsSpec": {
    "nodes": [
      {
        "hostname":         "{{ vcf.management_domain.operations.fqdn }}",
        "rootUserPassword": "{{ secrets.operations.root_pw }}",
        "type":             "master"
      }
    ],
    "adminUserPassword":     "{{ secrets.operations.admin_pw }}",
    "applianceSize":         "small",
    "useExistingDeployment": false
  },

  "vcfOperationsFleetManagementSpec": {
    "hostname":              "{{ vcf.management_domain.operations.fleet_fqdn }}",
    "rootUserPassword":      "{{ secrets.operations.root_pw }}",
    "adminUserPassword":     "{{ secrets.operations.admin_pw }}",
    "useExistingDeployment": false
  },

  "vcfOperationsCollectorSpec": {
    "hostname":              "{{ vcf.management_domain.operations.collector_fqdn }}",
    "rootUserPassword":      "{{ secrets.operations.root_pw }}",
    "applianceSize":         "small",
    "useExistingDeployment": false
  },

  "_lab_workarounds": {
    "comment": "由 Generate-BringupSpec.ps1 在 -LabMode 開啟時注入 / 修改",
    "notes": [
      "skipEsxThumbprintValidation/skipGatewayPingValidation 已預設 true (lab)",
      "9.0 沒有 9.1 那種 skipChecks 陣列, 控制旗標散在各個 spec 內"
    ]
  }
}
