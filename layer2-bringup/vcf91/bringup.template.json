{
  "_comment": "VCF 9.1 SddcSpec — schema 從 vcf-installer-openapi.json (354 KB) 抽出的 9.1 真實 schema, 不是 5.2.1 假設.",

  "sddcId": "{{ vcf.management_domain.name }}",
  "workflowType": "VCF",
  "ceipEnabled": false,
  "managementPoolName": "{{ vcf.management_domain.name }}-mgmt-pool",
  "skipEsxThumbprintValidation": true,
  "skipGatewayPingValidation": true,

  "dnsSpec": {
    "subdomain":   "{{ lab.domain }}",
    "domain":      "{{ lab.domain }}",
    "nameservers": ["{{ infra.ad_dns.ip }}"]
  },

  "ntpServers": ["{{ infra.ad_dns.ip }}"],

  "sddcManagerSpec": {
    "hostname":          "{{ vcf.management_domain.sddc_manager.fqdn | splitDot 0 }}",
    "rootPassword":      "{{ secrets.sddc_manager.root_pw }}",
    "sshPassword":       "{{ secrets.sddc_manager.admin_pw }}",
    "localUserPassword": "{{ secrets.sddc_manager.admin_pw }}"
  },

  "vcenterSpec": {
    "vcenterHostname":     "{{ vcf.management_domain.inner_vcenter.fqdn | splitDot 0 }}",
    "rootVcenterPassword": "{{ secrets.inner_vcenter.sso_admin_pw }}",
    "ssoDomain":           "vsphere.local",
    "vmSize":              "small",
    "storageSize":         "lstorage",
    "adminUserSsoUsername":"administrator@vsphere.local",
    "adminUserSsoPassword":"{{ secrets.inner_vcenter.sso_admin_pw }}"
  },

  "nsxtSpec": {
    "nsxtManagerSize":          "medium",
    "nsxtManagers": [
      { "hostname": "{{ vcf.management_domain.nsx_manager.node_fqdn | splitDot 0 | default 'kosten-vcf91-nsxn1' }}" }
    ],
    "vipFqdn":                  "{{ vcf.management_domain.nsx_manager.fqdn }}",
    "rootNsxtManagerPassword":  "{{ secrets.nsx.admin_pw }}",
    "nsxtAdminPassword":        "{{ secrets.nsx.admin_pw }}",
    "nsxtAuditPassword":        "{{ secrets.nsx.admin_pw }}",
    "transportVlanId":          {{ network.overlay.vlan | default 117 }},
    "ipAddressPoolSpec": {
      "name": "vcf-m02-tep-pool",
      "subnets": [
        {
          "cidr":    "{{ network.overlay.cidr }}",
          "gateway": "{{ network.overlay.gateway }}",
          "ipAddressPoolRanges": [
            { "start": "{{ vcf.management_domain.tep_pool.range_start }}", "end": "{{ vcf.management_domain.tep_pool.range_end }}" }
          ]
        }
      ]
    }
  },

  "datastoreSpec": {
    "vsanSpec": {
      "datastoreName":     "{{ vcf.management_domain.name }}-cl01-ds-vsan01",
      "failuresToTolerate": 0,
      "esaConfig":         { "enabled": true }
    }
  },

  "dvsSpecs": [
    {
      "dvsName":  "{{ vcf.management_domain.name }}-cl01-vds01",
      "mtu":      9000,
      "networks": ["MANAGEMENT","VSAN","VMOTION"],
      "vmnicsToUplinks": [
        { "id": "vmnic0", "uplink": "uplink1" },
        { "id": "vmnic1", "uplink": "uplink2" }
      ],
      "nsxTeamings": [
        { "policy": "LOADBALANCE_SRCID", "activeUplinks": ["uplink1","uplink2"], "standByUplinks": [] }
      ],
      "nsxtSwitchConfig": {
        "transportZones": [
          { "name": "vcf-m02-tz-overlay01", "transportType": "OVERLAY" },
          { "name": "vcf-m02-tz-vlan01",    "transportType": "VLAN"    }
        ]
      }
    }
  ],

  "networkSpecs": [
    {
      "networkType":  "MANAGEMENT",
      "subnet":       "{{ network.mgmt.cidr }}",
      "vlanId":       {{ network.mgmt.vlan }},
      "mtu":          1500,
      "gateway":      "{{ network.mgmt.gateway }}",
      "subnetMask":   "255.255.255.0",
      "portGroupKey": "{{ vcf.management_domain.name }}-cl01-vds01-pg-mgmt",
      "teamingPolicy": "loadbalance_loadbased",
      "activeUplinks":["uplink1","uplink2"],
      "standbyUplinks":[]
    },
    {
      "networkType":  "VSAN",
      "subnet":       "{{ network.vsan.cidr }}",
      "vlanId":       {{ network.vsan.vlan }},
      "mtu":          9000,
      "gateway":      "{{ network.vsan.gateway }}",
      "subnetMask":   "255.255.255.0",
      "portGroupKey": "{{ vcf.management_domain.name }}-cl01-vds01-pg-vsan",
      "includeIpAddressRanges": [
        { "startIpAddress": "{{ network.vsan.range_start }}", "endIpAddress": "{{ network.vsan.range_end }}" }
      ],
      "teamingPolicy": "loadbalance_loadbased",
      "activeUplinks":["uplink1","uplink2"],
      "standbyUplinks":[]
    },
    {
      "networkType":  "VM_MANAGEMENT",
      "subnet":       "{{ network.mgmt.cidr }}",
      "vlanId":       {{ network.mgmt.vlan }},
      "mtu":          1500,
      "gateway":      "{{ network.mgmt.gateway }}",
      "portGroupKey": "{{ vcf.management_domain.name }}-cl01-vds01-pg-vm-mgmt",
      "teamingPolicy": "loadbalance_loadbased",
      "activeUplinks":["uplink1","uplink2"],
      "standbyUplinks":[]
    },
    {
      "networkType":  "VMOTION",
      "subnet":       "{{ network.vmotion.cidr }}",
      "vlanId":       {{ network.vmotion.vlan }},
      "mtu":          9000,
      "gateway":      "{{ network.vmotion.gateway }}",
      "subnetMask":   "255.255.255.0",
      "portGroupKey": "{{ vcf.management_domain.name }}-cl01-vds01-pg-vmotion",
      "includeIpAddressRanges": [
        { "startIpAddress": "{{ network.vmotion.range_start }}", "endIpAddress": "{{ network.vmotion.range_end }}" }
      ],
      "teamingPolicy": "loadbalance_loadbased",
      "activeUplinks":["uplink1","uplink2"],
      "standbyUplinks":[]
    }
  ],

  "clusterSpec": {
    "datacenterName": "{{ vcf.management_domain.name }}-dc",
    "clusterName":    "{{ vcf.management_domain.name }}-cl01"
  },

  "_comment_fleetFqdn": "REQUIRED for primary VCF instance. Omitting it causes 'Save VCF Management Components' to fail with INVENTORY_INTERNAL_SERVER_ERROR (DB NOT NULL on fqdn for FLEET_LCM row). See docs/save-vcf-mgmt-components-fix.md.",
  "vspClusterSpec": {
    "instanceFqdn": "kosten-vcf91-vsp.rtolab.local",
    "platformFqdn": "kosten-vcf91-vspp.rtolab.local",
    "fleetFqdn":    "kosten-vcf91-fleet.rtolab.local",
    "systemUserPassword": "{{ secrets.sddc_manager.admin_pw }}",
    "size": "small",
    "ipv4Pool": {
      "ipRange": { "startIpAddress": "192.168.114.18", "endIpAddress": "192.168.114.29" }
    }
  },

  "hostSpecs": [
    { "hostname": "{{ hosts[0].fqdn | splitDot 0 }}", "credentials": { "username":"root", "password": "{{ secrets.esxi.root_pw }}" } },
    { "hostname": "{{ hosts[1].fqdn | splitDot 0 }}", "credentials": { "username":"root", "password": "{{ secrets.esxi.root_pw }}" } },
    { "hostname": "{{ hosts[2].fqdn | splitDot 0 }}", "credentials": { "username":"root", "password": "{{ secrets.esxi.root_pw }}" } },
    { "hostname": "{{ hosts[3].fqdn | splitDot 0 }}", "credentials": { "username":"root", "password": "{{ secrets.esxi.root_pw }}" } }
  ]
}
